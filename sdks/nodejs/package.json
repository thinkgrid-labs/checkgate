{
  "name": "@checkgate/node",
  "version": "0.1.14",
  "description": "Checkgate feature-flag SDK for Node.js — local evaluation via Rust NAPI.",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "napi": {
    "binaryName": "checkgate",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:zig": "napi build --platform --release --zig",
    "build:cross": "napi build --platform --release --use-napi-cross",
    "build:debug": "napi build --platform"
  },
  "dependencies": {
    "eventsource": "^4.1.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1"
  }
}
